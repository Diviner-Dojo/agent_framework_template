<?xml version="1.0" encoding="utf-8"?>
<!-- Network security config for just_audio's local audio server.
     just_audio serves audio bytes via a localhost HTTP server, which
     Android blocks by default (cleartext traffic policy). This config
     allows cleartext only for localhost while keeping HTTPS-only for
     all other domains.

     See: ADR-0022 (Voice Engine Swap) -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
